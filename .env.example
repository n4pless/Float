# Drift Clone - Environment Configuration

# Network
SOLANA_NETWORK=testnet
RPC_URL=https://api.testnet.solana.com

# Program IDs (update after deployment)
DRIFT_PROGRAM_ID=
USDC_MINT=

# Admin & Authority Keys
ADMIN_KEYPAIR_PATH=./keys/admin-keypair.json
KEEPER_KEYPAIR_PATH=./keys/keeper-keypair.json

# Oracle Configuration
PYTH_SOL_USD_ORACLE=J83w4HKfqxwcq3BEMMkPFSppX3gqekLyLJBexebFVkix

# Market Configuration
SOL_PERP_MARKET_INDEX=0
USDC_SPOT_MARKET_INDEX=0

# DLOB Server
DLOB_SERVER_PORT=3000
REDIS_URL=redis://localhost:6379

# Keeper Bots
FILLER_ENABLED=true
LIQUIDATOR_ENABLED=true
FUNDING_RATE_UPDATER_ENABLED=true

# Monitoring
LOG_LEVEL=info
ENABLE_METRICS=true
